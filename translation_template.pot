#: result.py:3895
msgid "Magdalena: Anyway... So you three are standing in front of this thing..."
msgstr ""

#: result.py:3896 result.py:4011
msgid "Magdalena: The cloaked figure stands in the center of the room, unmoving. Waiting for something, maybe..."
msgstr ""

#: result.py:3897
msgid "Decima: I run up and shake it! I say, 'Where is $! GIVE HER BACK!!'"
